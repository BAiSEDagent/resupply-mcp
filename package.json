{
  "name": "resupply-mcp",
  "version": "0.1.0",
  "description": "MCP + CLI for Resupply.fi - Agent-friendly yield farming",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "mcp": "tsx src/mcp/server.ts",
    "cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/mcp/server.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "resupply": "./dist/cli/index.js"
  },
  "keywords": [
    "resupply",
    "yield-farming",
    "curve",
    "frax",
    "mcp",
    "defi",
    "agent"
  ],
  "author": "BAiSED (@BAiSEDagent)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "viem": "^2.21.54",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "chalk": "^5.3.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
