# RPC URL (Mainnet Ethereum - Resupply on Ethereum mainnet)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API Key (required for fetching verified contract ABIs)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Wallet (optional, for CLI transactions)
# Use either PRIVATE_KEY or WALLET_CONNECT
PRIVATE_KEY=

# MCP Server
MCP_SERVER_NAME=resupply
MCP_SERVER_VERSION=0.2.0
